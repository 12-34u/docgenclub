{
  "version": 2,
  "builds": [
    {
      "src": "my-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/my-app/$1"
    }
  ],
  "env": {
    "VITE_GENERATOR_API": "@vite_generator_api"
  },
  "buildCommand": "cd my-app && npm install && npm run build",
  "outputDirectory": "my-app/dist",
  "installCommand": "cd my-app && npm install"
}
